/* pages/user/detail/index.wxss */

.container {
  min-height: 100vh;
  background: var(--bg-dark);
  padding-bottom: 40rpx;
}

/* Vant Tabs 深色主题样式 */
.custom-tabs {
  background: var(--bg-dark) !important;
}

.custom-tabs-nav {
  background: var(--bg-card) !important;
  border-bottom: 2rpx solid var(--border-color);
}

.custom-tab {
  color: var(--text-secondary) !important;
  font-size: var(--font-md) !important;
}

.custom-tab-active {
  color: #3b82f6 !important;
  font-weight: 600 !important;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: transparent;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(26, 41, 66, 0.8);
  backdrop-filter: blur(10rpx);
  border-radius: var(--radius-full);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

/* 用户头部 */
.user-header {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 24rpx 40rpx;
  background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg-dark) 100%);
  overflow: hidden;
}

/* 背景装饰 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(37, 99, 235, 0.1) 100%);
  z-index: 0;
}

.header-bg::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%);
  animation: rotate 20s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 头像容器 */
.avatar-wrapper {
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 6rpx solid var(--bg-dark);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.5);
}

.avatar-ring {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6, #ec4899) border-box;
  -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0.6;
  animation: pulse 3s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.05); }
}

/* 用户信息 */
.user-info {
  position: relative;
  z-index: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.user-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.user-bio {
  font-size: var(--font-md);
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
  max-width: 600rpx;
  padding: 0 20rpx;
}

/* 统计信息卡片 */
.stats-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx 24rpx;
  border: 2rpx solid var(--border-color);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
  width: calc(100% - 48rpx);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--text-muted);
  font-weight: 500;
}

.stat-divider {
  width: 2rpx;
  height: 40rpx;
  background: var(--border-color);
}

/* 操作按钮 */
.action-btns {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: var(--bg-dark);
}

.follow-btn, .message-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-md);
  font-weight: 600;
  border: none;
  transition: all 0.3s;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.follow-btn {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  position: relative;
  overflow: hidden;
}

.follow-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s;
}

.follow-btn:active::before {
  left: 100%;
}

.follow-btn.following {
  background: var(--bg-card);
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
}

.message-btn {
  background: var(--bg-card);
  color: var(--text-primary);
  border: 2rpx solid var(--border-color);
}

.follow-btn:active, .message-btn:active {
  transform: scale(0.95);
}

/* 文章列表 */
.article-list {
  padding: 20rpx;
}

/* 用户列表 */
.user-list {
  padding: 20rpx;
}

.user-item {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: 16rpx;
  border: 2rpx solid var(--border-color);
  transition: all 0.3s;
}

.user-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
  border-color: var(--primary-color);
}

.item-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid var(--border-color);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  justify-content: center;
}

.item-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.item-bio {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 60rpx 0;
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: var(--bg-dark);
}

/* 没有更多 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  font-size: var(--font-sm);
  color: var(--text-muted);
}

.no-more::before,
.no-more::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: var(--border-color);
  margin: 0 20rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
  gap: 24rpx;
}

.empty-text {
  font-size: var(--font-md);
  color: var(--text-muted);
  font-weight: 500;
}
