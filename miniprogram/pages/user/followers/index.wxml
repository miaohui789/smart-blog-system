<!-- pages/user/followers/index.wxml -->
<view class="container">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="goBack">
      <van-icon name="arrow-left" size="20px" color="#cbd5e1" />
    </view>
    <view class="nav-title">我的粉丝</view>
    <view class="nav-right"></view>
  </view>

  <!-- 统计信息 -->
  <view class="stats-bar">
    <text class="stats-text">共 {{total}} 位粉丝</text>
  </view>

  <!-- 用户列表 -->
  <view class="user-list">
    <view 
      class="user-item" 
      wx:for="{{users}}" 
      wx:key="id"
    >
      <view class="user-info" bindtap="goToUserProfile" data-id="{{item.id}}">
        <image class="avatar" src="{{item.avatar}}" mode="aspectFill" />
        <view class="info">
          <view class="nickname-row">
            <text class="nickname">{{item.nickname}}</text>
            <vip-badge wx:if="{{item.isVip}}" level="{{item.vipLevel}}" size="small" />
          </view>
          <text class="bio" wx:if="{{item.bio}}">{{item.bio}}</text>
          <view class="stats">
            <text class="stat-item">文章 {{item.articleCount || 0}}</text>
            <text class="stat-item">粉丝 {{item.fansCount || 0}}</text>
          </view>
        </view>
      </view>
      
      <view 
        class="action-btn {{item.isFollowing ? 'following' : 'follow'}}" 
        bindtap="handleFollow" 
        data-id="{{item.id}}"
        data-following="{{item.isFollowing}}"
      >
        <van-icon name="{{item.isFollowing ? 'success' : 'plus'}}" size="14px" color="{{item.isFollowing ? '#10b981' : '#3b82f6'}}" />
        <text>{{item.isFollowing ? '已关注' : '关注'}}</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <van-loading type="spinner" color="#3b82f6" />
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && users.length === 0}}">
    <van-icon name="friends-o" size="80px" color="#64748b" />
    <text class="empty-text">还没有粉丝</text>
    <text class="empty-desc">多发布优质内容吸引粉丝吧</text>
  </view>
</view>
