/* pages/user/profile/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  padding: 0 0 120rpx;
}

/* 顶部标题栏 */
.user-card .header,
.login-card .header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 24rpx;
}

.header-left {
  display: flex;
  align-items: center;
}

.header .title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.header .setting-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  backdrop-filter: blur(10rpx);
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #ff9a56 0%, #ff6b9d 50%, #c471ed 100%);
  border-radius: 0 0 32rpx 32rpx;
  padding: 48rpx 32rpx 40rpx;
  margin: 0 0 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 157, 0.4);
  position: relative;
  z-index: 10;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.avatar-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.avatar-wrapper .avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-wrapper .vip-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
}

.user-info .info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-info .nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.user-info .vip-expire {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
  backdrop-filter: blur(10rpx);
  align-self: flex-start;
}

/* 统计信息 */
.stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0 0;
  border-top: 2rpx solid rgba(255, 255, 255, 0.15);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-item .value {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.stat-item .label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 未登录状态 */
.login-card {
  background: linear-gradient(135deg, #ff9a56 0%, #ff6b9d 50%, #c471ed 100%);
  border-radius: 0 0 32rpx 32rpx;
  padding: 48rpx 32rpx 40rpx;
  margin: 0 0 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 157, 0.4);
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  margin-bottom: 24rpx;
}

.login-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

/* 菜单区域 */
.menu-section {
  margin: 0 24rpx 32rpx;
}

.section-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  padding: 0 12rpx 16rpx;
  font-weight: 500;
}

/* 菜单列表 */
.menu-list {
  background: rgba(30, 30, 46, 0.6);
  border-radius: 24rpx;
  overflow: hidden;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  transition: all 0.3s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.menu-item .left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-item .title {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.menu-item .right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-item .count {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.menu-item .badge {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: linear-gradient(135deg, #ff6b9d 0%, #f64f59 100%);
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
}

/* VIP会员中心 */
.vip-card {
  margin: 0 24rpx 32rpx;
  padding: 32rpx;
  background: linear-gradient(90deg, #ffd89b 0%, #c471ed 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.3);
}

.vip-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.vip-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.vip-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.vip-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.vip-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 更多功能 */
.more-section {
  margin: 0 24rpx 32rpx;
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  background: rgba(30, 30, 46, 0.6);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.function-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.function-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 退出登录 */
.logout-section {
  margin: 0 24rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  background: rgba(30, 30, 46, 0.6);
  border-radius: 24rpx;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
}

.logout-btn:active {
  background: rgba(255, 255, 255, 0.05);
}
