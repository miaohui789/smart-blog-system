/* pages/tag/detail/index.wxss */

.container {
  min-height: 100vh;
  background: var(--bg-dark);
  padding-bottom: 40rpx;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: var(--bg-card);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 2rpx solid var(--border-color);
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

/* 标签头部 */
.tag-header {
  display: flex;
  gap: 24rpx;
  padding: 32rpx 24rpx;
  background: var(--bg-card);
  border-bottom: 2rpx solid var(--border-color);
}

.tag-icon {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(5, 150, 105, 0.1) 100%);
  border-radius: var(--radius-lg);
  border: 2rpx solid rgba(16, 185, 129, 0.2);
}

.tag-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tag-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.tag-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.5;
}

.tag-stats {
  font-size: var(--font-xs);
  color: var(--text-muted);
}

/* 文章列表 */
.article-list {
  padding: 20rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 60rpx 0;
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

/* 没有更多 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  font-size: var(--font-sm);
  color: var(--text-muted);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  gap: 24rpx;
}

.empty-text {
  font-size: var(--font-md);
  color: var(--text-muted);
}
