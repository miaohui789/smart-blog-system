<!-- pages/search/index/index.wxml -->
<view class="container">
  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-box">
      <van-icon name="search" size="18px" color="#64748b" />
      <input 
        class="search-input" 
        placeholder="搜索文章、标签、用户..." 
        value="{{keyword}}"
        bindinput="onInput"
        bindconfirm="handleSearch"
        focus
      />
      <van-icon 
        wx:if="{{keyword}}" 
        name="clear" 
        size="18px" 
        color="#64748b" 
        bindtap="clearKeyword"
        class="clear-icon"
      />
    </view>
    <text class="cancel-btn" bindtap="goBack">取消</text>
  </view>

  <!-- 搜索建议 -->
  <view class="search-suggestions" wx:if="{{showSuggestions && !searched}}">
    <view 
      class="suggestion-item" 
      wx:for="{{suggestions}}" 
      wx:key="id"
      bindtap="selectSuggestion"
      data-type="{{item.type}}"
      data-title="{{item.title}}"
      data-id="{{item.id}}"
    >
      <!-- 用户类型显示头像 -->
      <image 
        wx:if="{{item.type === 'user' && item.avatar}}" 
        class="suggestion-avatar" 
        src="{{item.avatar}}" 
        mode="aspectFill"
      />
      <!-- 其他类型显示图标 -->
      <van-icon 
        wx:else
        name="{{item.icon}}" 
        size="18px" 
        color="#64748b" 
      />
      <view class="suggestion-content">
        <text class="suggestion-title">{{item.title}}</text>
        <text class="suggestion-subtitle">{{item.subtitle}}</text>
      </view>
      <van-icon name="arrow" size="16px" color="#64748b" />
    </view>
  </view>

  <!-- 搜索历史 -->
  <view class="search-history" wx:if="{{!searched && searchHistory.length > 0}}">
    <view class="section-header">
      <view class="section-title">
        <van-icon name="clock-o" size="18px" color="#64748b" />
        <text>搜索历史</text>
      </view>
      <text class="clear-history" bindtap="clearHistory">清空</text>
    </view>
    <view class="history-tags">
      <view 
        class="history-tag" 
        wx:for="{{searchHistory}}" 
        wx:key="index"
      >
        <text bindtap="searchHistory" data-keyword="{{item}}">{{item}}</text>
        <van-icon 
          name="cross" 
          size="12px" 
          color="#64748b" 
          class="tag-close"
          catchtap="deleteHistory"
          data-index="{{index}}"
        />
      </view>
    </view>
  </view>

  <!-- 热门搜索 -->
  <view class="hot-search" wx:if="{{!searched}}">
    <view class="section-title">
      <van-icon name="fire" size="18px" color="#f59e0b" />
      <text>热门搜索</text>
    </view>
    <view class="hot-list">
      <view 
        class="hot-item" 
        wx:for="{{hotKeywords}}" 
        wx:key="id"
        bindtap="searchHot"
        data-keyword="{{item.title}}"
      >
        <view class="hot-rank {{index < 3 ? 'top' : ''}}">{{index + 1}}</view>
        <text class="hot-title">{{item.title}}</text>
        <view class="hot-badge" wx:if="{{item.hot}}">热</view>
        <van-icon name="search" size="16px" color="#64748b" class="hot-icon" />
      </view>
    </view>
  </view>

  <!-- 搜索发现 -->
  <view class="search-discovery" wx:if="{{!searched}}">
    <view class="section-title">
      <text>搜索发现</text>
    </view>
    <view class="discovery-grid">
      <view 
        class="discovery-card" 
        wx:for="{{discoveries}}" 
        wx:key="id"
        bindtap="searchDiscovery"
        data-name="{{item.name}}"
        style="background: linear-gradient(135deg, {{item.color}}22 0%, {{item.color}}11 100%); border-color: {{item.color}}33;"
      >
        <view class="discovery-dot" style="background: {{item.color}}"></view>
        <text class="discovery-name" style="color: {{item.color}}">{{item.name}}</text>
        <text class="discovery-count">{{item.count}}</text>
      </view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="result-section" wx:if="{{searched && !loading}}">
    <!-- 文章结果 -->
    <view class="result-list" wx:if="{{articles.length > 0}}">
      <view class="result-count">
        找到 {{articles.length}} 篇文章
      </view>
      
      <view 
        class="article-card" 
        wx:for="{{articles}}" 
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <view class="card-left">
          <view class="author-row">
            <image class="author-avatar" src="{{item.author ? item.author.avatar : 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}" mode="aspectFill" />
            <text class="author-name">{{item.author ? item.author.nickname : '匿名用户'}}</text>
            <view class="vip-badge" wx:if="{{item.author && item.author.vipLevel > 0}}">VIP</view>
            <text class="publish-time">{{item.createTime || '刚刚'}}</text>
          </view>
          
          <view class="article-title">{{item.title}}</view>
          <view class="article-summary">{{item.summary}}</view>
          
          <view class="card-footer">
            <view class="category-tag">{{item.categoryName || '未分类'}}</view>
            <view class="article-stats">
              <view class="stat-item">
                <van-icon name="eye-o" size="12px" color="#64748b" />
                <text>{{item.viewCount}}</text>
              </view>
              <view class="stat-item">
                <van-icon name="good-job-o" size="12px" color="#64748b" />
                <text>{{item.likeCount}}</text>
              </view>
            </view>
          </view>
        </view>
        
        <image class="card-cover" src="{{item.cover}}" mode="aspectFill" wx:if="{{item.cover}}" />
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{articles.length === 0}}">
      <van-icon name="search" size="80px" color="#64748b" />
      <text class="empty-text">没有找到相关内容</text>
      <text class="empty-tip">换个关键词试试吧</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <van-loading type="spinner" color="#3b82f6" />
    <text>搜索中...</text>
  </view>
</view>
