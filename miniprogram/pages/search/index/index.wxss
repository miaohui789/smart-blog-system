/* pages/search/index/index.wxss */

.container {
  min-height: 100vh;
  background: var(--bg-dark);
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: var(--bg-dark);
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: var(--bg-input);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border-color);
}

.search-input {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text-primary);
}

.clear-icon {
  padding: 8rpx;
}

.cancel-btn {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  padding: 8rpx 16rpx;
}

/* 搜索建议 */
.search-suggestions {
  background: var(--bg-dark);
  padding: 0 20rpx;
}

.suggestion-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  margin-bottom: 12rpx;
  border: 1rpx solid var(--border-color);
  transition: all 0.3s;
}

.suggestion-item:active {
  background: var(--bg-card-hover);
  transform: translateX(8rpx);
}

.suggestion-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 1rpx solid var(--border-color);
}

.suggestion-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.suggestion-title {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
}

.suggestion-subtitle {
  font-size: var(--font-xs);
  color: var(--text-muted);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

/* 搜索历史 */
.search-history {
  padding: 32rpx 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.clear-history {
  font-size: var(--font-sm);
  color: var(--text-muted);
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: var(--bg-card);
  color: var(--text-secondary);
  font-size: var(--font-sm);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border-color);
}

.history-tag text {
  flex: 1;
}

.history-tag:active {
  background: var(--bg-card-hover);
}

.tag-close {
  padding: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 热门搜索 */
.hot-search {
  padding: 32rpx 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.hot-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hot-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-color);
  transition: all 0.3s;
}

.hot-item:active {
  background: var(--bg-card-hover);
  transform: translateX(8rpx);
}

.hot-rank {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-input);
  color: var(--text-muted);
  font-size: var(--font-md);
  font-weight: 700;
  border-radius: var(--radius-sm);
}

.hot-rank.top {
  background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%);
  color: #fff;
}

.hot-title {
  flex: 1;
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
}

.hot-badge {
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #fff;
  font-size: var(--font-xs);
  border-radius: var(--radius-sm);
}

.hot-icon {
  color: var(--text-muted);
}

/* 搜索发现 */
.search-discovery {
  padding: 32rpx 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.discovery-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.discovery-card {
  padding: 32rpx 24rpx;
  border-radius: var(--radius-lg);
  border: 1rpx solid;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.discovery-card:active {
  transform: scale(0.95);
}

.discovery-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-full);
  margin-bottom: 16rpx;
}

.discovery-name {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  margin-bottom: 8rpx;
}

.discovery-count {
  display: block;
  font-size: var(--font-xs);
  color: var(--text-muted);
}

/* 搜索结果 */
.result-section {
  padding: 20rpx;
}

.result-count {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

/* 文章卡片 */
.article-card {
  display: flex;
  gap: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--border-color);
  transition: all 0.3s;
}

.article-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
  border-color: var(--primary-color);
}

.card-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.author-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid var(--border-color);
}

.author-name {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.vip-badge {
  padding: 2rpx 8rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
  color: #1e293b;
  font-size: 18rpx;
  font-weight: 700;
  border-radius: 6rpx;
}

.publish-time {
  margin-left: auto;
  font-size: var(--font-xs);
  color: var(--text-muted);
}

.article-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.article-summary {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}

.category-tag {
  padding: 4rpx 12rpx;
  background: rgba(59, 130, 246, 0.15);
  color: var(--primary-color);
  font-size: var(--font-xs);
  border-radius: var(--radius-sm);
  border: 1rpx solid rgba(59, 130, 246, 0.3);
}

.article-stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: var(--font-xs);
  color: var(--text-muted);
}

.card-cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  background: var(--bg-input);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  gap: 16rpx;
}

.empty-text {
  font-size: var(--font-md);
  color: var(--text-muted);
}

.empty-tip {
  font-size: var(--font-sm);
  color: var(--text-disabled);
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 200rpx 0;
  font-size: var(--font-sm);
  color: var(--text-secondary);
}
