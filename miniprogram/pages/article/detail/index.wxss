/* pages/article/detail/index.wxss */

.container {
  min-height: 100vh;
  background: var(--bg-dark);
  padding-bottom: 140rpx;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: var(--bg-card);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 2rpx solid var(--border-color);
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

/* 文章标题 */
.article-title {
  padding: 32rpx 24rpx 24rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
}

/* 作者信息 */
.author-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 24rpx 24rpx;
}

.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid var(--border-color);
}

.author-info {
  flex: 1;
}

.author-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.vip-badge {
  padding: 2rpx 12rpx;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #fff;
  font-size: 20rpx;
  border-radius: var(--radius-full);
  font-weight: 600;
}

.article-meta {
  font-size: var(--font-xs);
  color: var(--text-muted);
}

.dot {
  margin: 0 8rpx;
}

.follow-btn {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  font-size: var(--font-sm);
  border-radius: var(--radius-full);
  font-weight: 600;
}

.follow-btn.following {
  background: var(--bg-input);
  color: var(--text-secondary);
}

/* 标签区域 */
.tags-section {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 24rpx 24rpx;
}

.tag-item {
  padding: 8rpx 20rpx;
  background: rgba(59, 130, 246, 0.1);
  color: #3b82f6;
  font-size: var(--font-sm);
  border-radius: var(--radius-full);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
}

/* 统计区域 */
.stats-section {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 0 24rpx 24rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--font-sm);
  color: var(--text-muted);
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: var(--border-color);
  margin: 0 24rpx 32rpx;
}

/* 文章内容 */
.article-content {
  padding: 0 24rpx 32rpx;
  font-size: var(--font-md);
  color: var(--text-primary);
  line-height: 1.8;
}

.article-content rich-text {
  word-break: break-word;
}

/* 评论区 */
.comment-section {
  padding: 32rpx 24rpx;
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  transition: all 0.3s;
}

.comment-item:active {
  background: rgba(59, 130, 246, 0.05);
  border-radius: var(--radius-md);
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
}

.comment-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.comment-nickname {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.comment-text {
  font-size: var(--font-md);
  color: var(--text-primary);
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.comment-meta {
  font-size: var(--font-xs);
  color: var(--text-muted);
}

.empty-comment {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 80rpx 0;
  color: var(--text-muted);
  font-size: var(--font-sm);
}

/* 加载中 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: var(--bg-dark);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: var(--bg-card);
  border-top: 2rpx solid var(--border-color);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.input-box {
  flex: 1;
  padding: 16rpx 24rpx;
  background: var(--bg-input);
  border-radius: var(--radius-full);
}

.placeholder {
  font-size: var(--font-sm);
  color: var(--text-muted);
}

.action-btns {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.action-btn text {
  font-size: 20rpx;
  color: var(--text-muted);
}

.action-btn text.active {
  color: #3b82f6;
}

/* 评论弹窗 */
.comment-popup {
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.comment-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: var(--bg-input);
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  color: var(--text-primary);
  border: 1rpx solid var(--border-color);
}

.popup-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
}

.char-count {
  font-size: var(--font-xs);
  color: var(--text-muted);
}

.send-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  border: none;
  border-radius: var(--radius-full);
  font-size: var(--font-md);
  font-weight: 600;
}

/* 评论右侧区域 */
.comment-right {
  flex: 1;
}

.comment-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.comment-like {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: var(--font-xs);
  color: var(--text-muted);
}

.comment-like text.liked {
  color: #3b82f6;
}

.comment-footer {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 8rpx;
}

.comment-time {
  font-size: var(--font-xs);
  color: var(--text-muted);
}

.reply-btn {
  font-size: var(--font-xs);
  color: #3b82f6;
}

/* 展开/收起回复按钮 */
.toggle-replies-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  margin-top: 16rpx;
  background: rgba(59, 130, 246, 0.05);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  border-radius: var(--radius-md);
  font-size: var(--font-sm);
  color: #3b82f6;
  font-weight: 500;
  transition: all 0.3s;
}

.toggle-replies-btn:active {
  background: rgba(59, 130, 246, 0.1);
  transform: scale(0.98);
}

/* 回复列表 */
.reply-list {
  margin-top: 12rpx;
  padding: 20rpx;
  background: var(--bg-input);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-color);
}

.reply-item {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 0;
  transition: all 0.3s;
}

.reply-item:active {
  background: rgba(59, 130, 246, 0.05);
  border-radius: var(--radius-sm);
}

.reply-item:not(:last-child) {
  border-bottom: 1rpx solid var(--border-color);
  margin-bottom: 4rpx;
}

.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.reply-right {
  flex: 1;
}

.reply-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.reply-user {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.reply-nickname {
  font-size: var(--font-xs);
  font-weight: 600;
  color: var(--text-primary);
}

.reply-to {
  font-size: var(--font-xs);
  color: var(--text-muted);
}

.reply-like {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: var(--text-muted);
}

.reply-like text.liked {
  color: #3b82f6;
}

.reply-text {
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: 6rpx;
}

.reply-footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.reply-time {
  font-size: 20rpx;
  color: var(--text-muted);
}

/* 加载更多评论 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  font-size: var(--font-sm);
  color: #3b82f6;
}
