/* pages/notification/index/index.wxss */
@import '../../../styles/variables.wxss';

.container {
  min-height: 100vh;
  background: var(--bg-dark);
  padding-bottom: 120rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: var(--bg-card);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 2rpx solid var(--border-color);
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.action-text {
  font-size: var(--font-sm);
  color: #3b82f6;
}

/* 未读提示 */
.unread-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  margin: 20rpx 20rpx 0;
  background: rgba(59, 130, 246, 0.1);
  border-radius: var(--radius-lg);
  border: 2rpx solid rgba(59, 130, 246, 0.2);
  font-size: var(--font-sm);
  color: #3b82f6;
}

/* 通知列表 */
.notification-list {
  padding: 20rpx;
}

.notification-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid var(--border-color);
  position: relative;
  transition: all 0.3s;
}

.notification-item.unread {
  background: rgba(59, 130, 246, 0.05);
  border-color: rgba(59, 130, 246, 0.3);
}

.notification-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
}

.icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-wrapper.COMMENT {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.icon-wrapper.LIKE {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.icon-wrapper.FOLLOW {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.icon-wrapper.SYSTEM {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
}

.message {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.time {
  font-size: var(--font-xs);
  color: var(--text-muted);
  margin-top: 4rpx;
}

.actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.delete-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(239, 68, 68, 0.1);
  border-radius: 50%;
  transition: all 0.3s;
}

.delete-btn:active {
  background: rgba(239, 68, 68, 0.2);
  transform: scale(0.95);
}

.unread-dot {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ef4444;
  border-radius: 50%;
  box-shadow: 0 0 12rpx rgba(239, 68, 68, 0.6);
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 60rpx 0;
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  gap: 24rpx;
}

.empty-text {
  font-size: var(--font-md);
  color: var(--text-muted);
}

/* 底部操作 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--bg-card);
  border-top: 2rpx solid var(--border-color);
  z-index: 100;
}

.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: rgba(239, 68, 68, 0.1);
  border-radius: var(--radius-lg);
  font-size: var(--font-md);
  color: #ef4444;
  border: 2rpx solid rgba(239, 68, 68, 0.2);
  transition: all 0.3s;
}

.clear-btn:active {
  background: rgba(239, 68, 68, 0.2);
  transform: scale(0.98);
}
