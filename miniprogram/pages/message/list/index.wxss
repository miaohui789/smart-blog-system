/* pages/message/list/index.wxss */

.container {
  min-height: 100vh;
  background: var(--bg-dark);
}

/* 搜索框 */
.search-bar {
  padding: 20rpx 24rpx;
  background: var(--bg-dark);
  border-bottom: 1rpx solid var(--border-color);
}

/* 会话列表 */
.conversation-list {
  padding: 0;
}

.conversation-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-color);
  transition: all 0.3s;
  position: relative;
}

.conversation-item:active {
  background: var(--bg-card-hover);
}

/* 头像区域 */
.avatar-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--bg-input);
  border: 2rpx solid var(--border-color);
}

/* 未读消息徽章 - 左上角 */
.unread-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  background: #ff4444;
  border-radius: 50%;
  font-size: 20rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  border: 3rpx solid var(--bg-card);
  box-shadow: 0 2rpx 8rpx rgba(255, 68, 68, 0.4);
  z-index: 2;
}

/* 在线状态指示器 - 右下角 */
.online-indicator {
  position: absolute;
  bottom: 2rpx;
  right: 2rpx;
  width: 24rpx;
  height: 24rpx;
  background: #10b981;
  border-radius: 50%;
  border: 3rpx solid var(--bg-card);
  box-shadow: 0 0 8rpx rgba(16, 185, 129, 0.6);
  z-index: 2;
}

/* 信息内容 */
.conversation-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.username-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.username {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time {
  font-size: 24rpx;
  color: var(--text-muted);
  flex-shrink: 0;
  margin-left: 16rpx;
}

.bottom-row {
  display: flex;
  align-items: center;
}

.last-message {
  font-size: 28rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  line-height: 1.4;
}
