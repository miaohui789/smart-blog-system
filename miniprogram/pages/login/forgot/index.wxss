/* pages/login/forgot/index.wxss */

.container {
  min-height: 100vh;
  background: var(--bg-dark);
  padding: 40rpx;
  position: relative;
}

.back-btn {
  position: absolute;
  top: 40rpx;
  left: 40rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  border-radius: 50%;
  border: 2rpx solid var(--border-color);
  z-index: 10;
}

/* 步骤指示器 */
.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 80rpx;
  margin-bottom: 80rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.step-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-muted);
  transition: all 0.3s;
}

.step-item.active .step-circle {
  background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
  border-color: #a855f7;
  color: #fff;
}

.step-text {
  font-size: var(--font-sm);
  color: var(--text-muted);
}

.step-item.active .step-text {
  color: #a855f7;
  font-weight: 600;
}

.step-line {
  width: 120rpx;
  height: 4rpx;
  background: var(--border-color);
  margin: 0 16rpx;
  transition: all 0.3s;
}

.step-line.active {
  background: linear-gradient(90deg, #a855f7 0%, #7c3aed 100%);
}

/* 步骤内容 */
.step-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-icon {
  margin-bottom: 32rpx;
}

.step-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.step-desc {
  font-size: var(--font-md);
  color: var(--text-muted);
  margin-bottom: 64rpx;
}

/* 验证区域 */
.verify-area {
  width: 100%;
  height: 300rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.verify-placeholder {
  font-size: var(--font-md);
  color: var(--text-muted);
}

/* 滑块验证 */
.slider-container {
  width: 100%;
  margin-bottom: 32rpx;
  position: relative;
}

.slider-track {
  width: 100%;
  height: 96rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--border-color);
  position: relative;
  overflow: hidden;
}

.slider-fill {
  height: 100%;
  background: linear-gradient(90deg, rgba(245, 158, 11, 0.2) 0%, rgba(245, 158, 11, 0.4) 100%);
  transition: width 0.1s;
}

.slider-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: var(--font-md);
  color: var(--text-muted);
  pointer-events: none;
  white-space: nowrap;
}

.slider-btn {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
  transition: all 0.3s;
  cursor: grab;
}

.slider-btn:active {
  cursor: grabbing;
}

.slider-btn.success {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

/* 表单 */
.form {
  width: 100%;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--border-color);
  transition: all 0.3s;
}

.input-wrapper:focus-within {
  border-color: #a855f7;
  box-shadow: 0 0 0 6rpx rgba(168, 85, 247, 0.1);
}

.form-input {
  flex: 1;
  font-size: var(--font-md);
  color: var(--text-primary);
}

.eye-icon {
  cursor: pointer;
  flex-shrink: 0;
}

.code-wrapper {
  padding-right: 16rpx;
}

.code-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
  color: #fff;
  border: none;
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  font-weight: 600;
  white-space: nowrap;
}

.code-btn.disabled {
  background: var(--bg-input);
  color: var(--text-muted);
}

/* 下一步按钮 */
.next-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
  color: #fff;
  border: none;
  border-radius: var(--radius-full);
  font-size: var(--font-lg);
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(168, 85, 247, 0.3);
  transition: all 0.3s;
}

.next-btn:active {
  transform: scale(0.98);
}
