/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: var(--bg-dark);
  padding-bottom: 120rpx;
}

/* 顶部搜索栏 */
.top-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--bg-dark);
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: var(--bg-input);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border-color);
}

.search-placeholder {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text-muted);
}

.refresh-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-input);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border-color);
  transition: transform 0.3s ease;
}

.refresh-icon.rotating {
  animation: rotate 1s ease-in-out;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.history-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-input);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border-color);
}

/* 轮播图 */
.banner-section {
  padding: 0 20rpx 20rpx;
}

.banner-swiper {
  width: 100%;
  height: 320rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx 24rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, transparent 100%);
}

.banner-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

/* 快捷入口 */
.quick-entry {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  padding: 0 20rpx 32rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.entry-icon {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s;
}

.entry-item:active .entry-icon {
  transform: scale(0.9);
}

.entry-name {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  text-align: center;
}

/* 分区标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: var(--font-sm);
  color: var(--text-muted);
}

/* 文章列表 */
.article-list {
  padding: 0 20rpx;
}

.article-card {
  display: flex;
  gap: 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--border-color);
  transition: all 0.3s;
}

.article-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
  border-color: var(--primary-color);
}

/* 左侧内容 */
.card-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 作者信息行 */
.author-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid var(--border-color);
}

.author-name {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.vip-badge {
  padding: 2rpx 8rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
  color: #1e293b;
  font-size: 18rpx;
  font-weight: 700;
  border-radius: 6rpx;
}

.publish-time {
  margin-left: auto;
  font-size: var(--font-xs);
  color: var(--text-muted);
}

/* 文章标题 */
.article-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 文章摘要 */
.article-summary {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}

.footer-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.category-tag {
  padding: 4rpx 12rpx;
  background: rgba(59, 130, 246, 0.15);
  color: var(--primary-color);
  font-size: var(--font-xs);
  border-radius: var(--radius-sm);
  border: 1rpx solid rgba(59, 130, 246, 0.3);
  white-space: nowrap;
}

.publish-time {
  font-size: var(--font-xs);
  color: var(--text-muted);
  white-space: nowrap;
}

/* 文章统计 */
.article-stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: var(--font-xs);
  color: var(--text-muted);
}

/* 右侧封面 */
.card-cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  background: var(--bg-input);
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 60rpx 0;
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

/* 没有更多 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  font-size: var(--font-sm);
  color: var(--text-muted);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  gap: 24rpx;
}

.empty-text {
  font-size: var(--font-md);
  color: var(--text-muted);
}
