/* packageVip/pages/center/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  padding-bottom: 40rpx;
}

/* 顶部背景 */
.header-bg {
  background: linear-gradient(135deg, #ffd89b 0%, #c471ed 100%);
  border-radius: 0 0 48rpx 48rpx;
  padding-bottom: 40rpx;
  position: relative;
  overflow: hidden;
}

.header-bg::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, transparent 70%);
  border-radius: 50%;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  position: relative;
  z-index: 10;
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

/* VIP卡片 */
.vip-card {
  margin: 0 32rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.vip-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.vip-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.vip-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.vip-level {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.vip-expire {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.vip-progress {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #10b981 0%, #34d399 100%);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
}

/* 非VIP卡片 */
.non-vip-card {
  margin: 0 32rpx;
  padding: 60rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.non-vip-icon {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  margin-bottom: 8rpx;
}

.non-vip-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.non-vip-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 区块 */
.section {
  margin: 32rpx 24rpx 0;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 12rpx 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

/* 特权网格 */
.privilege-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.privilege-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx 24rpx;
  background: rgba(30, 30, 46, 0.6);
  border-radius: 24rpx;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.privilege-icon {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.privilege-name {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.privilege-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 激活卡片 */
.activate-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 32rpx;
  background: rgba(30, 30, 46, 0.6);
  border-radius: 24rpx;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.input-wrapper {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  overflow: hidden;
}

.activate-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.4);
  transition: all 0.3s;
}

.activate-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.4);
}

/* 等级列表 */
.level-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: rgba(30, 30, 46, 0.6);
  border-radius: 24rpx;
  padding: 24rpx;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.level-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.05);
}

.level-badge {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  flex-shrink: 0;
}

.level-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.level-name {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.level-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.5;
}

.level-check {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(16, 185, 129, 0.1);
  border-radius: 50%;
}

/* 使用记录 */
.record-list {
  background: rgba(30, 30, 46, 0.6);
  border-radius: 24rpx;
  overflow: hidden;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.record-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(245, 158, 11, 0.1);
  border-radius: 50%;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.record-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.record-count {
  font-size: 28rpx;
  font-weight: 600;
  color: #f59e0b;
}

.empty-record {
  padding: 80rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* FAQ列表 */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.faq-item {
  background: rgba(30, 30, 46, 0.6);
  border-radius: 16rpx;
  overflow: hidden;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  transition: all 0.3s;
}

.faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.faq-answer {
  padding: 0 24rpx 24rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.8;
  animation: fadeIn 0.3s;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
