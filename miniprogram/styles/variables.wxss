/* variables.wxss - 样式变量（深蓝色暗色主题） */

page {
  /* 主色调 - 青蓝色渐变 */
  --primary-color: #3b82f6;
  --primary-light: #60a5fa;
  --primary-dark: #2563eb;
  --secondary-color: #06b6d4;
  --accent-color: #8b5cf6;

  /* 深色主题背景 - 深蓝色调 */
  --bg-dark: #0a1628;
  --bg-darker: #050d1a;
  --bg-card: #1a2942;
  --bg-card-hover: #243a5e;
  --bg-input: #152238;
  --bg-overlay: rgba(26, 41, 66, 0.95);

  /* 浅色主题背景 */
  --bg-light: #ffffff;
  --bg-light-gray: #f5f5f5;
  --bg-card-light: #ffffff;

  /* 文字颜色 */
  --text-primary: #e2e8f0;
  --text-secondary: #94a3b8;
  --text-muted: #64748b;
  --text-disabled: #475569;

  /* 浅色主题文字 */
  --text-primary-light: #1e293b;
  --text-secondary-light: #475569;
  --text-muted-light: #64748b;

  /* 边框颜色 */
  --border-color: #1e3a5f;
  --border-light: #2d4a6f;
  --border-color-light: #e2e8f0;

  /* 功能色 */
  --success-color: #10b981;
  --warning-color: #f59e0b;
  --error-color: #ef4444;
  --info-color: #3b82f6;

  /* 阴影 - 深蓝色调 */
  --shadow-sm: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
  --shadow-md: 0 8rpx 12rpx rgba(0, 0, 0, 0.6);
  --shadow-lg: 0 20rpx 30rpx rgba(0, 0, 0, 0.7);
  --shadow-glow: 0 0 40rpx rgba(59, 130, 246, 0.4);
  --shadow-card: 0 4rpx 12rpx rgba(0, 0, 0, 0.4);

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-full: 9999rpx;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;

  /* 字体大小 */
  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-2xl: 40rpx;
  --font-3xl: 48rpx;
}
